{
  "name": "shinobi-desktop",
  "version": "0.4.0",
  "private": true,
  "main": "dist/main.js",
  "homepage": "https://github.com/mhensberg2003/shinobi",
  "scripts": {
    "build:native": "node scripts/build-native-macos.mjs",
    "build:native:bundle": "node scripts/build-native-macos.mjs --bundle-dylibs",
    "dev": "pnpm run build:native && tsc && electron dist/main.js",
    "build": "pnpm run build:native && tsc",
    "start": "pnpm run build:native && electron dist/main.js",
    "package": "pnpm run build:native:bundle && dotenv -e .env -- electron-builder",
    "release": "pnpm run build:native:bundle && electron-builder --publish always"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "typescript": "^5"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
